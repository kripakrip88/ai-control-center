{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@ai-control/shared-types": ["./packages/shared-types/src"],
      "@ai-control/database": ["./packages/database/src"],
      "@ai-control/auth": ["./packages/auth/src"],
      "@ai-control/shared-config": ["./packages/shared-config/src"],
      "@ai-control/event-bus": ["./packages/event-bus/src"],
      "@ai-control/api-client": ["./packages/api-client/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
