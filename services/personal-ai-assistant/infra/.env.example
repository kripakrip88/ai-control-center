# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=n8n

# ==========================================
# n8n
# ==========================================
N8N_USER=admin
N8N_PASSWORD=change_me_in_production
N8N_HOST=localhost

# ==========================================
# Telegram Bot
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_GROUPS=-1001234567890,-1009876543210

# ==========================================
# AI APIs
# ==========================================
# Используем только Anthropic Claude для LLM
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here

# Embeddings: HuggingFace sentence-transformers (локально, без API ключа)
# Модель: sentence-transformers/all-MiniLM-L6-v2

