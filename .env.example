# =============================================================================
# AI Control Center - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=aicontrol
POSTGRES_PASSWORD=change-in-production
POSTGRES_DB=aicontrol_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database URLs for each service
ERP_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=erp
AI_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=ai
TELEGRAM_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=telegram

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# AI Services Configuration
# -----------------------------------------------------------------------------
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (local LLM)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Service URLs (Internal Communication)
# -----------------------------------------------------------------------------
ERP_SERVICE_HOST=erp-web
ERP_SERVICE_PORT=3000
ERP_SERVICE_URL=http://${ERP_SERVICE_HOST}:${ERP_SERVICE_PORT}

AI_POLYGON_HOST=ai-polygon
AI_POLYGON_PORT=4000
AI_POLYGON_URL=http://${AI_POLYGON_HOST}:${AI_POLYGON_PORT}

MEMORY_SERVICE_HOST=memory-service
MEMORY_SERVICE_PORT=8000
MEMORY_SERVICE_URL=http://${MEMORY_SERVICE_HOST}:${MEMORY_SERVICE_PORT}

TELEGRAM_BOT_HOST=telegram-bot
TELEGRAM_BOT_PORT=3001
TELEGRAM_BOT_URL=http://${TELEGRAM_BOT_HOST}:${TELEGRAM_BOT_PORT}

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# N8n Workflow Automation
N8N_USER=admin
N8N_PASSWORD=n8n_admin_2024
N8N_WEBHOOK_URL=http://n8n:5678/webhook

# OCR Service
OCR_SERVICE_URL=http://tesseract:8868

# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# -----------------------------------------------------------------------------
# Upload & Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Backend Public URL (for callbacks)
# -----------------------------------------------------------------------------
BACKEND_PUBLIC_URL=http://localhost:4000
