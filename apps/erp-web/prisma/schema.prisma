generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MaterialType {
  STEEL
  STAINLESS
  ALUMINUM
  GALVANIZED
}

enum ProfileType {
  RECTANGULAR_TUBE
  ROUND_TUBE
  ANGLE
  CHANNEL
  BEAM
  SHEET
  PLATE
  FLAT_BAR
  ROUND_BAR
  FASTENER
}

enum CurrencyCode {
  RUB
  USD
  EUR
}

enum PurchaseUnit {
  METER
  TON
  SHEET
  PIECE
  SQUARE_METER
}

enum MeasurementType {
  LINEAR
  AREA
  PIECE
}

enum OrderStatus {
  DRAFT
  QUOTATION
  AWAITING_APPROVAL
  APPROVED
  PRODUCTION
  COMPLETED
  DELIVERED
  CANCELLED
}

enum OrderMode {
  STANDARD
  PHASED
}

enum PhaseStatus {
  PLANNED
  IN_PRODUCTION
  READY
  SHIPPED
}

enum RevisionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SUPERSEDED
}

enum UserRole {
  ADMIN
  MANAGER
  ENGINEER
  VIEWER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  RESTORE
  STATUS_CHANGE
  PRICE_UPDATE
  REVISION_SNAPSHOT
}

enum FileType {
  PDF
  DWG
  DXF
  STEP
  IMAGE
  OTHER
}

enum CostCategory {
  MATERIAL
  CUTTING
  WELDING
  BENDING
  PAINTING
  GALVANIZING
  OUTSOURCING
  DELIVERY
  OVERHEAD
  MARGIN
  DISCOUNT
  OTHER
}

enum WorkCenterType {
  LASER
  BANDSAW
  LATHE
  WELDING
  BENDING
  OTHER
}

enum OperationType {
  CUT
  BEND
  WELD
  DRILL
  PAINT
  ASSEMBLE
  OTHER
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum SteelGrade {
  S235
  S245
  S345
  S355
  S09G2S
  AISI304
  AISI316
  OTHER
}

enum CoatingType {
  PRIMER
  BASE_COAT
  TOPCOAT
  CLEAR
  OTHER
}

enum AssemblyRevisionStatus {
  DRAFT
  FROZEN
  ARCHIVED
}

enum MaterialDomain {
  STRUCTURAL
  FASTENER
  COATING
  CONSUMABLE
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  taxId     String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  materialDefinitions MaterialDefinition[]
  materialCategories  MaterialCategory[]
  procurementProfiles ProcurementProfile[]
  orders              Order[]
  auditLogs           AuditLog[]
  files               ManagedFile[]
  outboxEvents        OutboxEvent[]
  stockItems          StockItem[]
  exchangeRates       ExchangeRate[]
  workCenters         WorkCenter[]
  coatingMaterials     CoatingMaterial[]
  coatingSystems       CoatingSystem[]
  materialReservations MaterialReservation[]
  inventoryBalances    InventoryBalance[]
  productTemplates     ProductTemplate[]
  customers            Customer[]

  @@map("companies")
}

model User {
  id           String    @id @default(uuid())
  companyId    String
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(VIEWER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  version      Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company   Company         @relation(fields: [companyId], references: [id])
  orders    Order[]         @relation("CreatedByUser")
  revisions QuoteRevision[] @relation("RevisionCreatedBy")
  auditLogs AuditLog[]
  interactionsCreated Interaction[] @relation("InteractionCreatedBy")

  @@map("users")
}

model MaterialDefinition {
  id           String       @id @default(uuid())
  companyId    String
  code         String
  name         String
  materialType MaterialType
  profileType  ProfileType
  steelGrade   SteelGrade?
  geometryId   String       @unique
  categoryId     String?
  materialDomain MaterialDomain @default(STRUCTURAL)
  pieceUnit      String?        @default("pcs")
  description  String?
  standard     String?
  strengthClass String?
  isActive     Boolean      @default(true)
  version      Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  company             Company              @relation(fields: [companyId], references: [id])
  geometry            MaterialGeometry     @relation(fields: [geometryId], references: [id])
  category            MaterialCategory?    @relation(fields: [categoryId], references: [id])
  procurementProfiles   ProcurementProfile[]
  parts                 Part[]
  stockItems            StockItem[]
  templateNodeParts     ProductTemplateNodePart[]

  @@unique([companyId, code])
  @@map("material_definitions")
}

model MaterialCategory {
  id        String    @id @default(uuid())
  companyId String
  slug      String
  name      String
  parentId  String?
  position  Int       @default(0)
  domain    String    @default("STRUCTURAL")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company            @relation(fields: [companyId], references: [id])
  parent    MaterialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  MaterialCategory[] @relation("CategoryTree")
  materials MaterialDefinition[]

  @@unique([companyId, slug])
  @@map("material_categories")
}

model MaterialGeometry {
  id                        String          @id @default(uuid())
  width                     Decimal?        @db.Decimal(12, 4)
  height                    Decimal?        @db.Decimal(12, 4)
  thickness                 Decimal?        @db.Decimal(12, 4)
  diameter                  Decimal?        @db.Decimal(12, 4)
  innerDiameter             Decimal?        @db.Decimal(12, 4)
  sheetWidth                Decimal?        @db.Decimal(12, 4)
  sheetLength               Decimal?        @db.Decimal(12, 4)
  measurementType           MeasurementType
  theoreticalWeightPerMeter Decimal?        @db.Decimal(12, 6)
  actualWeightPerMeter      Decimal?        @db.Decimal(12, 6)
  weightPerSquareMeter      Decimal?        @db.Decimal(12, 6)
  paintSurfacePerMeter      Decimal?        @db.Decimal(12, 6)
  unitWeightKg              Decimal?        @db.Decimal(12, 4)
  densityKgM3               Int?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  materialDefinition MaterialDefinition?

  @@map("material_geometries")
}

model ProcurementProfile {
  id                   String       @id @default(uuid())
  companyId            String
  materialDefinitionId String
  supplierName         String
  supplierCode         String?
  standardLength       Decimal?     @db.Decimal(12, 4)
  purchaseUnit         PurchaseUnit @default(METER)
  minOrderQty          Decimal?     @db.Decimal(12, 4)
  coatingVariant       String?
  isPreferred          Boolean      @default(false)
  isActive             Boolean      @default(true)
  notes                String?
  pricePerPiece        Decimal?     @db.Decimal(14, 4)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  company            Company            @relation(fields: [companyId], references: [id])
  materialDefinition MaterialDefinition @relation(fields: [materialDefinitionId], references: [id])
  prices             MaterialPrice[]
  supplierMappings   SupplierMapping[]

  @@map("procurement_profiles")
}

model MaterialPrice {
  id                   String       @id @default(uuid())
  procurementProfileId String
  pricePerTon          Decimal      @db.Decimal(14, 4)
  currency             CurrencyCode @default(RUB)
  validFrom            DateTime
  validTo              DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  procurementProfile ProcurementProfile @relation(fields: [procurementProfileId], references: [id])

  @@map("material_prices")
}

model SupplierMapping {
  id                   String   @id @default(uuid())
  procurementProfileId String
  supplierName         String
  rawText              String
  confirmedAt          DateTime
  confirmedById        String?
  createdAt            DateTime @default(now())

  procurementProfile ProcurementProfile @relation(fields: [procurementProfileId], references: [id])

  @@unique([supplierName, rawText])
  @@map("supplier_mappings")
}

model ExchangeRate {
  id           String       @id @default(uuid())
  companyId    String
  fromCurrency CurrencyCode
  toCurrency   CurrencyCode
  rate         Decimal      @db.Decimal(16, 8)
  validAt      DateTime
  source       String?
  createdAt    DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, fromCurrency, toCurrency, validAt])
  @@map("exchange_rates")
}

model Order {
  id           String      @id @default(uuid())
  companyId    String
  createdById  String
  customerId   String?
  orderNumber  String
  customerName String
  title        String
  description  String?
  status       OrderStatus @default(DRAFT)
  mode         OrderMode   @default(STANDARD)
  dueDate      DateTime?
  version      Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt             DateTime?
  activeQuoteRevisionId String?

  company             Company         @relation(fields: [companyId], references: [id])
  createdBy           User            @relation("CreatedByUser", fields: [createdById], references: [id])
  customer            Customer?       @relation(fields: [customerId], references: [id])
  phases              Phase[]
  assemblies          Assembly[]
  revisions           QuoteRevision[]  @relation("OrderRevisions")
  activeQuoteRevision QuoteRevision?   @relation("ActiveQuoteRevision", fields: [activeQuoteRevisionId], references: [id], onDelete: SetNull)
  files               OrderFile[]
  materialReservations MaterialReservation[]
  interactions        Interaction[]

  @@unique([companyId, orderNumber])
  @@index([activeQuoteRevisionId])
  @@index([customerId])
  @@map("orders")
}

model Phase {
  id              String      @id @default(uuid())
  orderId         String
  name            String
  phaseNumber     Int
  status          PhaseStatus @default(PLANNED)
  plannedShipDate DateTime?
  actualShipDate  DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  order      Order      @relation(fields: [orderId], references: [id])
  assemblies Assembly[]

  @@unique([orderId, phaseNumber])
  @@map("phases")
}

model Assembly {
  id                String      @id @default(uuid())
  orderId           String
  phaseId           String?
  parentId          String?
  name              String
  description       String?
  qty                   Int         @default(1)
  position              Int         @default(0)
  version               Int         @default(1)
  projectSteelGrade     SteelGrade?
  actualSteelGrade      SteelGrade?
  currentRevisionId     String?
  releasedRevisionId    String?
  sourceTemplateId      String?
  sourceTemplateVersion Int?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  order            Order             @relation(fields: [orderId], references: [id])
  phase            Phase?            @relation(fields: [phaseId], references: [id])
  parent           Assembly?         @relation("AssemblyTree", fields: [parentId], references: [id])
  children         Assembly[]        @relation("AssemblyTree")
  parts            Part[]
  routingSteps     RoutingStep[]
  coatings         AssemblyCoating[]
  revisions        AssemblyRevision[]  @relation("AssemblyRevisions")
  currentRevision  AssemblyRevision?   @relation("CurrentRevision",  fields: [currentRevisionId],  references: [id], onDelete: SetNull)
  releasedRevision AssemblyRevision?   @relation("ReleasedRevision", fields: [releasedRevisionId], references: [id], onDelete: Restrict)
  sourceTemplate   ProductTemplate?    @relation(fields: [sourceTemplateId], references: [id])

  @@index([currentRevisionId])
  @@index([releasedRevisionId])
  @@index([sourceTemplateId])
  @@map("assemblies")
}

model Part {
  id                   String          @id @default(uuid())
  assemblyId           String
  materialDefinitionId String?
  name                 String?
  measurementType      MeasurementType @default(LINEAR)
  length               Decimal?        @db.Decimal(12, 4)
  sheetWidth           Decimal?        @db.Decimal(12, 4)
  sheetHeight          Decimal?        @db.Decimal(12, 4)
  directWeightKg       Decimal?        @db.Decimal(12, 4)
  surfaceAreaM2        Decimal?        @db.Decimal(12, 4)
  quantity             Int
  notes                String?
  position             Int             @default(0)
  bomTemplateCode      String?
  bomTemplateId        String?
  bomTemplateVersion   Int?
  bomGroupKey          String?
  bomGroupLabel        String?
  bomDepth             Int?
  bomPath              Json?
  bomSortPath          String?
  partCategory         String          @default("MATERIAL")
  stableUid            String          @default(cuid())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  // AI normalization fields
  aiGenerated          Boolean         @default(false)
  aiRawText            String?
  aiNormResultId       String?
  aiConfidence         Float?
  aiMatchMethod        String?
  aiStatus             String?

  assembly           Assembly            @relation(fields: [assemblyId], references: [id])
  materialDefinition MaterialDefinition? @relation(fields: [materialDefinitionId], references: [id])

  @@index([partCategory])
  @@index([aiGenerated])
  @@map("parts")
}

model WorkCenter {
  id        String         @id @default(uuid())
  companyId String
  name      String
  type      WorkCenterType
  qty       Int            @default(1)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  routingSteps RoutingStep[]

  @@map("work_centers")
}

model RoutingStep {
  id            String        @id @default(uuid())
  assemblyId    String
  workCenterId  String
  operationType OperationType
  sequence      Int
  estimatedMin  Int?
  actualMin     Int?
  status        StepStatus    @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assembly   Assembly   @relation(fields: [assemblyId], references: [id])
  workCenter WorkCenter @relation(fields: [workCenterId], references: [id])

  @@map("routing_steps")
}

model QuoteRevision {
  id                        String         @id @default(uuid())
  orderId                   String
  createdById               String
  revisionNumber            Int
  status                    RevisionStatus @default(DRAFT)
  notes                     String?
  currency                  CurrencyCode   @default(RUB)
  calculationVersion        String         @default("2.0")
  sourceReleasedRevisionIds Json?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  order          Order    @relation("OrderRevisions", fields: [orderId], references: [id])
  createdBy      User     @relation("RevisionCreatedBy", fields: [createdById], references: [id])
  activeForOrder Order[]  @relation("ActiveQuoteRevision")
  parts            RevisionPart[]
  costLines        RevisionCostLine[]
  calculation      RevisionCalculation?
  assemblyCoatings RevisionAssemblyCoating[]

  @@unique([orderId, revisionNumber])
  @@index([orderId, status])
  @@map("quote_revisions")
}

model RevisionPart {
  id                        String   @id @default(uuid())
  revisionId                String
  materialDefinitionId      String?
  procurementProfileId      String?
  materialCode              String
  materialName              String
  name                      String?
  materialType              String
  profileType               String
  steelGrade                String?
  standard                  String?
  supplierName              String
  supplierCode              String?
  measurementType           String
  length                    Decimal? @db.Decimal(12, 4)
  sheetWidth                Decimal? @db.Decimal(12, 4)
  sheetHeight               Decimal? @db.Decimal(12, 4)
  directWeightKg            Decimal? @db.Decimal(12, 4)
  quantity                  Int
  assemblyQty               Int      @default(1)
  theoreticalWeightPerMeter Decimal? @db.Decimal(12, 6)
  actualWeightPerMeter      Decimal? @db.Decimal(12, 6)
  weightPerSquareMeter      Decimal? @db.Decimal(12, 6)
  paintSurfacePerMeter      Decimal? @db.Decimal(12, 6)
  calculatedWeightPerUnit   Decimal  @db.Decimal(12, 4)
  totalWeight               Decimal  @db.Decimal(12, 4)
  paintAreaM2               Decimal? @db.Decimal(12, 4)
  pricePerTon               Decimal  @db.Decimal(14, 4)
  pricePerPiece             Decimal? @db.Decimal(14, 4)
  currency                  String
  materialCost              Decimal  @db.Decimal(14, 4)
  assemblyName              String?
  phaseName                 String?
  notes                     String?
  position                  Int      @default(0)
  bomTemplateCode           String?
  bomTemplateId             String?
  bomTemplateVersion        Int?
  bomGroupKey               String?
  bomGroupLabel             String?
  bomDepth                  Int?
  bomPath                   Json?
  bomSortPath               String?

  revision QuoteRevision @relation(fields: [revisionId], references: [id])

  @@map("revision_parts")
}

model RevisionCostLine {
  id          String       @id @default(uuid())
  revisionId  String
  category    CostCategory
  label       String
  description String?
  amount      Decimal      @db.Decimal(14, 4)
  currency    CurrencyCode @default(RUB)
  isManual    Boolean      @default(false)
  sortOrder   Int          @default(0)

  revision QuoteRevision @relation(fields: [revisionId], references: [id])

  @@map("revision_cost_lines")
}

model RevisionCalculation {
  id                 String       @id @default(uuid())
  revisionId         String       @unique
  calculationVersion String
  calculatedAt       DateTime     @default(now())
  totalWeightKg      Decimal      @db.Decimal(14, 4)
  totalMaterialCost  Decimal      @db.Decimal(14, 4)
  totalCost          Decimal      @db.Decimal(14, 4)
  totalPaintM2       Decimal?     @db.Decimal(14, 4)
  currency           CurrencyCode
  materialSummary    Json
  weightBreakdown    Json
  costBreakdown      Json
  pricingSummary     Json
  warnings           Json         @default("[]")

  revision QuoteRevision @relation(fields: [revisionId], references: [id])

  @@map("revision_calculations")
}

model ManagedFile {
  id          String    @id @default(uuid())
  companyId   String
  fileType    FileType
  title       String
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  versions     FileVersion[]
  orders       OrderFile[]
  certificates Certificate[]

  @@map("managed_files")
}

model FileVersion {
  id            String   @id @default(uuid())
  fileId        String
  versionNumber Int
  originalName  String
  storagePath   String
  storageUrl    String
  mimeType      String
  sizeBytes     BigInt
  uploadedById  String?
  changeNotes   String?
  createdAt     DateTime @default(now())

  file ManagedFile @relation(fields: [fileId], references: [id])

  @@unique([fileId, versionNumber])
  @@map("file_versions")
}

model OrderFile {
  id         String   @id @default(uuid())
  orderId    String
  fileId     String
  attachedAt DateTime @default(now())

  order Order       @relation(fields: [orderId], references: [id])
  file  ManagedFile @relation(fields: [fileId], references: [id])

  @@unique([orderId, fileId])
  @@map("order_files")
}

model Certificate {
  id           String    @id @default(uuid())
  fileId       String
  supplierName String
  issuedAt     DateTime
  expiresAt    DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  file ManagedFile @relation(fields: [fileId], references: [id])

  @@map("certificates")
}

model StockItem {
  id                   String       @id @default(uuid())
  companyId            String
  materialDefinitionId String
  procurementProfileId String?
  warehouseLocation    String?
  lotNumber            String?
  quantityOnHand       Decimal      @db.Decimal(12, 4)
  unit                 PurchaseUnit
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  company            Company            @relation(fields: [companyId], references: [id])
  materialDefinition MaterialDefinition @relation(fields: [materialDefinitionId], references: [id])
  remnants           Remnant[]

  @@map("stock_items")
}

model Remnant {
  id                 String   @id @default(uuid())
  stockItemId        String
  length             Decimal? @db.Decimal(12, 4)
  width              Decimal? @db.Decimal(12, 4)
  weightKg           Decimal? @db.Decimal(12, 4)
  isReserved         Boolean  @default(false)
  reservedForOrderId String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  stockItem StockItem @relation(fields: [stockItemId], references: [id])

  @@map("remnants")
}

model AuditLog {
  id            String      @id @default(uuid())
  companyId     String
  userId        String?
  entity        String
  entityId      String
  action        AuditAction
  diff          Json?
  snapshot      Json?
  correlationId String?
  eventId       String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([companyId, createdAt])
  @@index([correlationId])
  @@map("audit_logs")
}

model OutboxEvent {
  id            String    @id @default(uuid())
  companyId     String
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  processedAt   DateTime?
  failedAt      DateTime?
  retryCount    Int       @default(0)
  error         String?
  createdAt     DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([processedAt, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model CoatingMaterial {
  id                        String      @id @default(uuid())
  companyId                 String
  code                      String
  name                      String
  coatingType               CoatingType
  consumptionGm2            Decimal     @db.Decimal(10, 4)
  referenceDftMkm           Int
  densityKgL                Decimal     @db.Decimal(8, 4)
  recommendedDilutionPercent Decimal?   @db.Decimal(5, 2)
  pricePerKg                Decimal?    @db.Decimal(12, 2)
  supplierName              String?
  notes                     String?
  isActive                  Boolean     @default(true)
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  company              Company               @relation(fields: [companyId], references: [id])
  assemblyCoatings     AssemblyCoating[]
  systemLayers         CoatingSystemLayer[]
  materialReservations MaterialReservation[]
  inventoryBalances    InventoryBalance[]

  @@unique([companyId, code])
  @@map("coating_materials")
}

model AssemblyCoating {
  id                   String      @id @default(uuid())
  assemblyId           String
  coatingMaterialId    String
  coatingSystemId      String?
  layerNumber          Int         @default(1)
  autoAreaLink         Boolean     @default(true)
  manualAreaM2         Decimal?    @db.Decimal(12, 4)
  selectedDftMkm       Int?
  dilutionPercent      Decimal?    @db.Decimal(5, 2)
  notes                String?
  position             Int         @default(0)
  materialCodeSnapshot       String?
  materialNameSnapshot       String?
  lossFactorPercent          Decimal?    @db.Decimal(5, 2)
  theoreticalConsumptionKg   Decimal?    @db.Decimal(12, 4)
  finalConsumptionKg         Decimal?    @db.Decimal(12, 4)
  costSnapshotPerKg          Decimal?    @db.Decimal(12, 2)
  // snapshot-derived estimate — NOT accounting fact; do not use for procurement, invoicing, or financial reporting
  calculatedCost             Decimal?    @db.Decimal(14, 2)
  createdAt                  DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  assembly        Assembly        @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  coatingMaterial CoatingMaterial @relation(fields: [coatingMaterialId], references: [id])
  coatingSystem   CoatingSystem?  @relation(fields: [coatingSystemId], references: [id], onDelete: SetNull)

  @@unique([assemblyId, layerNumber])
  @@index([assemblyId])
  @@index([coatingSystemId])
  @@map("assembly_coatings")
}

model CoatingSystem {
  id          String   @id @default(uuid())
  companyId   String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  position    Int      @default(0)
  uiColor     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company              @relation(fields: [companyId], references: [id])
  assemblyCoatings AssemblyCoating[]
  layers           CoatingSystemLayer[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@index([companyId, position])
  @@map("coating_systems")
}

model CoatingSystemLayer {
  id                     String   @id @default(uuid())
  coatingSystemId        String
  coatingMaterialId      String
  layerNumber            Int
  defaultDftMkm          Int?
  defaultDilutionPercent Decimal? @db.Decimal(5, 2)
  notes                  String?
  position               Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  coatingSystem   CoatingSystem   @relation(fields: [coatingSystemId], references: [id], onDelete: Cascade)
  coatingMaterial CoatingMaterial @relation(fields: [coatingMaterialId], references: [id])

  @@unique([coatingSystemId, layerNumber])
  @@unique([coatingSystemId, position])
  @@map("coating_system_layers")
}

model RevisionAssemblyCoating {
  id              String   @id @default(uuid())
  revisionId      String
  assemblyId      String
  assemblyName    String
  coatingCode     String
  coatingName     String
  coatingType     String
  layerNumber     Int
  position        Int      @default(0)
  areaM2          Decimal  @db.Decimal(12, 4)
  consumptionKg   Decimal  @db.Decimal(12, 4)
  consumptionL    Decimal? @db.Decimal(12, 4)
  totalKg         Decimal  @db.Decimal(12, 4)
  selectedDftMkm  Int
  dilutionPercent Decimal  @db.Decimal(5, 2)
  pricePerKg         Decimal? @db.Decimal(12, 2)
  totalCost          Decimal? @db.Decimal(14, 2)
  assemblyRevisionId String?

  revision         QuoteRevision     @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  assemblyRevision AssemblyRevision? @relation(fields: [assemblyRevisionId], references: [id], onDelete: SetNull)

  @@index([assemblyRevisionId])
  @@map("revision_assembly_coatings")
}

model AssemblyRevision {
  id                    String                 @id @default(uuid())
  assemblyId            String
  revisionNumber        Int
  status                AssemblyRevisionStatus @default(DRAFT)
  createdFromRevisionId String?
  notes                 String?
  frozenAt              DateTime?
  frozenByUserId        String?
  freezeReason          String?
  // Aggregated financial totals — computed at freeze time, immutable thereafter.
  // NOTE: snapshot-derived ERP estimate — not an accounting fact.
  // TODO: labor totals, material totals, routing totals, overhead totals,
  //   margin totals, tax snapshots, multi-currency totals
  totalTheoreticalConsumptionKg Decimal? @db.Decimal(14, 4)
  totalFinalConsumptionKg       Decimal? @db.Decimal(14, 4)
  totalCalculatedCost           Decimal? @db.Decimal(16, 2)
  createdByUserId       String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  assembly               Assembly                          @relation("AssemblyRevisions", fields: [assemblyId], references: [id], onDelete: Cascade)
  createdFromRevision    AssemblyRevision?                 @relation("RevisionChain", fields: [createdFromRevisionId], references: [id])
  derivedRevisions       AssemblyRevision[]                @relation("RevisionChain")
  coatingSnapshots       AssemblyRevisionCoatingSnapshot[]
  currentForAssemblies   Assembly[]                        @relation("CurrentRevision")
  releasedForAssemblies  Assembly[]                        @relation("ReleasedRevision")
  revisionCoatingLinks   RevisionAssemblyCoating[]
  materialReservations   MaterialReservation[]

  @@unique([assemblyId, revisionNumber])
  @@index([assemblyId, status])
  @@index([assemblyId, revisionNumber])
  @@map("assembly_revisions")
}

model AssemblyRevisionCoatingSnapshot {
  id                        String   @id @default(uuid())
  assemblyRevisionId        String
  assemblyId                String
  coatingMaterialId         String?
  materialCodeSnapshot      String
  materialNameSnapshot      String
  layerNumber               Int
  position                  Int      @default(0)
  selectedDftMkm            Int?
  dilutionPercent           Decimal? @db.Decimal(5, 2)
  lossFactorPercent         Decimal? @db.Decimal(5, 2)
  theoreticalConsumptionKg  Decimal? @db.Decimal(12, 4)
  finalConsumptionKg        Decimal? @db.Decimal(12, 4)
  costSnapshotPerKg         Decimal? @db.Decimal(12, 2)
  calculatedCost            Decimal? @db.Decimal(14, 2)
  calculationFormulaVersion String?
  pricingFormulaVersion     String?
  createdAt                 DateTime @default(now())

  assemblyRevision     AssemblyRevision      @relation(fields: [assemblyRevisionId], references: [id], onDelete: Cascade)
  materialReservations MaterialReservation[]

  @@index([assemblyRevisionId])
  @@index([assemblyId])
  @@map("assembly_revision_coating_snapshots")
}

enum ReservationType {
  PROCUREMENT
  PRODUCTION
  MANUAL
}

enum ReservationStatus {
  RESERVED
  RELEASED
  CANCELLED
}

model MaterialReservation {
  id                  String            @id @default(cuid())
  companyId           String
  orderId             String
  assemblyRevisionId  String
  materialId          String
  coatingSnapshotId   String?
  reservationType     ReservationType   @default(PROCUREMENT)
  status              ReservationStatus @default(RESERVED)
  reservedQuantity    Decimal           @db.Decimal(12, 4)
  unit                String            @default("kg")
  notes               String?
  reservedAt          DateTime          @default(now())
  releasedAt          DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  company          Company                          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  order            Order                            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  assemblyRevision AssemblyRevision                 @relation(fields: [assemblyRevisionId], references: [id], onDelete: Restrict)
  material         CoatingMaterial                  @relation(fields: [materialId], references: [id], onDelete: Restrict)
  coatingSnapshot  AssemblyRevisionCoatingSnapshot? @relation(fields: [coatingSnapshotId], references: [id], onDelete: SetNull)

  @@unique([companyId, assemblyRevisionId, materialId, coatingSnapshotId])
  @@index([orderId])
  @@index([assemblyRevisionId])
  @@index([materialId])
  @@index([status])
  @@map("material_reservations")
}

// Inventory balances are compatibility abstractions, not warehouse transactions.
// Reserved quantities are derived exclusively from immutable reservation records.
// Available quantity must never be computed from live engineering workspace state.
model InventoryBalance {
  id                String   @id @default(cuid())
  companyId         String
  materialId        String
  uom               String   @default("kg")
  physicalQuantity  Decimal  @db.Decimal(15, 4) @default(0)
  reservedQuantity  Decimal  @db.Decimal(15, 4) @default(0)
  availableQuantity Decimal  @db.Decimal(15, 4) @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  material CoatingMaterial @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@unique([companyId, materialId])
  @@index([companyId])
  @@index([materialId])
  @@map("inventory_balances")
}

model ProductTemplate {
  id                   String    @id @default(uuid())
  companyId            String
  code                 String
  name                 String
  description          String?
  isActive             Boolean   @default(true)
  version              Int       @default(1)
  estimatedWeightKg    Decimal?  @db.Decimal(12, 4)
  estimatedPaintAreaM2 Decimal?  @db.Decimal(12, 4)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  company    Company               @relation(fields: [companyId], references: [id])
  nodes      ProductTemplateNode[]
  assemblies Assembly[]

  @@unique([companyId, code])
  @@map("product_templates")
}

// MAX_DEPTH = 3. Depth enforced at application level, not DB level.
model ProductTemplateNode {
  id           String    @id @default(uuid())
  templateId   String
  parentNodeId String?
  name         String
  qty          Int       @default(1)
  position     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  template  ProductTemplate           @relation(fields: [templateId], references: [id])
  parent    ProductTemplateNode?      @relation("NodeTree", fields: [parentNodeId], references: [id])
  children  ProductTemplateNode[]     @relation("NodeTree")
  parts     ProductTemplateNodePart[]

  @@map("product_template_nodes")
}

model ProductTemplateNodePart {
  id                   String          @id @default(uuid())
  nodeId               String
  materialDefinitionId String
  measurementType      MeasurementType
  length               Decimal?        @db.Decimal(12, 4)
  sheetWidth           Decimal?        @db.Decimal(12, 4)
  sheetHeight          Decimal?        @db.Decimal(12, 4)
  directWeightKg       Decimal?        @db.Decimal(12, 4)
  surfaceAreaM2        Decimal?        @db.Decimal(12, 4)
  quantity             Int
  notes                String?
  position             Int             @default(0)

  node               ProductTemplateNode @relation(fields: [nodeId], references: [id])
  materialDefinition MaterialDefinition  @relation(fields: [materialDefinitionId], references: [id])

  @@map("product_template_node_parts")
}

enum CustomerPriority {
  VIP
  HIGH
  NORMAL
  LOW
}

enum InteractionType {
  EMAIL
  CALL
  MEETING
  NOTE
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

model Customer {
  id          String           @id @default(uuid())
  companyId   String
  name        String
  inn         String?
  phone       String?
  email       String?
  website     String?
  notes       String?
  priority    CustomerPriority @default(NORMAL)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  company      Company       @relation(fields: [companyId], references: [id])
  contacts     Contact[]
  orders       Order[]
  interactions Interaction[]

  @@index([companyId])
  @@index([email])
  @@map("crm_customers")
}

model Contact {
  id         String   @id @default(uuid())
  customerId String
  name       String
  phone      String?
  email      String?
  position   String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  interactions Interaction[]

  @@index([customerId])
  @@index([email])
  @@map("crm_contacts")
}

model Interaction {
  id             String               @id @default(uuid())
  customerId     String
  contactId      String?
  orderId        String?
  type           InteractionType
  direction      InteractionDirection
  subject        String?
  body           String?
  emailMessageId String?              @unique
  createdAt      DateTime             @default(now())
  createdById    String

  customer  Customer  @relation(fields: [customerId], references: [id])
  contact   Contact?  @relation(fields: [contactId], references: [id])
  order     Order?    @relation(fields: [orderId], references: [id])
  createdBy User      @relation("InteractionCreatedBy", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([orderId])
  @@map("crm_interactions")
}
